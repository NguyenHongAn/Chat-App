\r\n        else{\r\n            toast.error(result.error, {\r\n                position: toast.POSITION.TOP_RIGHT,\r\n            });\r\n        }\r\n    }\r\n\r\n    const loginWithGoogle = ()=>{\r\n        const result = Service.loginWithGoogleAccount();\r\n        //console.log(result);\r\n        // if (result[0] === \"success\")\r\n        // {\r\n        //     //dispatch(ReduxAction.AUTH.updateJwtToken(result[1].jwtAction));\r\n        // }\r\n        // else{\r\n        //     toast.error(result.error, {\r\n        //         position: toast.POSITION.TOP_RIGHT,\r\n        //     });\r\n        // }\r\n    }\r\n    return (\r\n        <Grid container component=\"main\" className={classes.root}>\r\n            <CssBaseline ></CssBaseline>\r\n            <Grid item xs={false} sm={4} md={7} className={classes.image} >    \r\n            </Grid>\r\n            <Grid item \r\n            container spacing={1}\r\n            xs={12} sm={8} md={5} \r\n            className={classes.paper}>\r\n                <Grid item container>\r\n                    <Grid item xs className={classes.linkGroup}>\r\n                        <ArrowBackIosIcon fontSize=\"small\" \r\n                        ></ArrowBackIosIcon>\r\n                        <Link className={classes.link}\r\n                        to=\"/\">\r\n                            Homepage\r\n                        </Link>\r\n                    </Grid>\r\n                </Grid>\r\n                <Avatar className={classes.avatar}>\r\n                    <LockOutlinedIcon></LockOutlinedIcon>\r\n                </Avatar>\r\n                <form className={classes.form}\r\n                onSubmit={handleLogin}> \r\n                    <TextField\r\n                    id=\"username\"\r\n                    type='text'\r\n                    margin=\"normal\"\r\n                    required\r\n                    placeholder=\"Username *\"\r\n                    autoFocus\r\n                    fullWidth\r\n                    variant=\"outlined\"\r\n                    className={classes.inputText}\r\n                    onChange={handleUsername}></TextField>\r\n                    <TextField\r\n                    id=\"password\"\r\n                    type='password'\r\n                    placeholder=\"Password *\"\r\n                    margin=\"normal\"\r\n                    required\r\n                    fullWidth\r\n                    variant=\"outlined\"\r\n                    className={classes.inputText}\r\n                    onChange={handlePassword}></TextField>\r\n                    <FormControlLabel\r\n                    control={<Checkbox value=\"remember\" color=\"primary\" />}\r\n                    label=\"Remember me\"\r\n                    />\r\n                    <Button\r\n                    type=\"submit\"\r\n                    className={classes.button} \r\n                    fullWidth                      \r\n                    >Sign In</Button>\r\n                    <Grid container justify=\"space-around\" spacing={1}>\r\n                        <Grid container item xs sm={6} md={6} spacing={1}>\r\n                            <Button \r\n                            fullWidth \r\n                            style={{\r\n                                backgroundColor: \"#3b5998\",\r\n                                color: \"white\",\r\n                            }}\r\n                            startIcon={<FacebookIcon/>}>\r\n                                Sign in with Facebook\r\n                            </Button>\r\n                        </Grid>\r\n                        <Grid container item xs sm={6} md={6} spacing={1}>\r\n                            <Button \r\n                            fullWidth\r\n                            onClick={loginWithGoogle}\r\n                            style={{\r\n                                backgroundColor: \"#DB4437\",\r\n                                color: \"white\",\r\n                            }}>\r\n                                Sign in with Google\r\n                            </Button>\r\n                        </Grid>\r\n                    </Grid>\r\n                    <Grid container spacing={1}>\r\n                        <Grid item xs className={classes.linkGroup}>\r\n                            <Link className={classes.link}\r\n                            to=\"/fogot-password\">\r\n                                Fogot password?\r\n                            </Link>\r\n                        </Grid>\r\n                        <Grid item className={classes.linkGroup}>\r\n                            <Link className={classes.link}\r\n                            to=\"/signup\">\r\n                                {\"Don't have an account? Sign Up\"}\r\n                            </Link>\r\n                        </Grid>\r\n                    </Grid>\r\n                </form>\r\n            </Grid>\r\n        </Grid>\r\n    )\r\n}\r\n\r\nexport default SignIn;\r\n","E:\\React\\Chat App\\chat-app\\src\\components\\Signin\\styles.js",[],["77","78"],"E:\\React\\Chat App\\chat-app\\src\\store\\actions\\index.js",[],"E:\\React\\Chat App\\chat-app\\src\\api\\index.js",[],"E:\\React\\Chat App\\chat-app\\src\\components\\SignUp\\index.js",["79","80","81","82"],"import React,{useState} from 'react';\r\nimport useStyles from './styles';\r\nimport {CssBaseline,\r\nTextField,\r\nAvatar,\r\nCheckbox,\r\nFormControlLabel,\r\nButton,\r\nGrid,\r\nTypography } from \"@material-ui/core\";\r\nimport {Link} from 'react-router-dom';\r\nimport LockOutlinedIcon from '@material-ui/icons/LockOutlined';\r\nimport ArrowBackIosIcon from '@material-ui/icons/ArrowBackIos';\r\n\r\nimport Service from \"./services\";\r\nimport {toast} from 'react-toastify';\r\nimport {useDispatch} from 'react-redux';\r\nimport ReduxAction from '../../store/actions';\r\n\r\n\r\nfunction SignUp () {\r\n    const classes = useStyles();\r\n    const [email, setEmail]= useState('');\r\n    const [password, setPassword] = useState(\"\");\r\n    const [username, setUsername] = useState(\"\");\r\n    //const [rePass, setRePass] = useState(\"\");\r\n\r\n    //const handlePassword = (e) => setPassword(e.target.value);\r\n    const handleUsername = (e) => setUsername(e.target.value);\r\n    const handleEmail= (e) => setEmail(e.target.value);\r\n    const validatePassword =(e)=>{\r\n        const result = Service.validatePassword(password, e.target.value);\r\n        if (result[0] !== \"Success\")\r\n        {\r\n            toast.error(result[1],{\r\n                position: toast.POSITION.TOP_RIGHT,\r\n                draggable: false,\r\n            });\r\n        }\r\n        else\r\n        {\r\n            setPassword(e.target.value);\r\n        }\r\n    }\r\n    const createNewAccount = () =>{\r\n\r\n    }\r\n\r\n    return (\r\n        <Grid container component=\"main\" className={classes.root}>\r\n            <CssBaseline ></CssBaseline>\r\n            <Grid item xs={false} sm={4} md={7} className={classes.image} >    \r\n            </Grid>\r\n            <Grid item \r\n            container spacing={1}\r\n            xs={12} sm={8} md={5} \r\n            className={classes.paper}>\r\n                <Grid item container>\r\n                    <Grid item xs className={classes.linkGroup}>\r\n                        <ArrowBackIosIcon fontSize=\"small\" \r\n                        ></ArrowBackIosIcon>\r\n                        <Link className={classes.link}\r\n                        to=\"/\">\r\n                            Homepage\r\n                        </Link>\r\n                    </Grid>\r\n                </Grid>\r\n                <Avatar className={classes.avatar}>\r\n                    <LockOutlinedIcon></LockOutlinedIcon>\r\n                </Avatar>\r\n                <Typography component=\"h1\" variant=\"h5\">\r\n                    Sign up\r\n                </Typography>\r\n                <form className={classes.form}\r\n                onSubmit={createNewAccount}\r\n                > \r\n                    <TextField\r\n                    id=\"username\"\r\n                    type='text'\r\n                    margin=\"normal\"\r\n                    required\r\n                    placeholder=\"Username *\"\r\n                    autoFocus\r\n                    fullWidth\r\n                    variant=\"outlined\"\r\n                    className={classes.inputText}\r\n                    onChange={handleUsername}\r\n                    ></TextField>\r\n                    <TextField\r\n                    id=\"email\"\r\n                    type='text'\r\n                    margin=\"normal\"\r\n                    required\r\n                    placeholder=\"Email *\"\r\n                    autoFocus\r\n                    fullWidth\r\n                    variant=\"outlined\"\r\n                    className={classes.inputText}\r\n                    onChange={handleEmail}\r\n                    ></TextField>\r\n                    <TextField\r\n                    id=\"password\"\r\n                    type='password'\r\n                    placeholder=\"Password *\"\r\n                    margin=\"normal\"\r\n                    required\r\n                    fullWidth\r\n                    onChange={validatePassword}\r\n                    variant=\"outlined\"\r\n                    className={classes.inputText}\r\n                    ></TextField>\r\n                    <TextField\r\n                    id=\"rePassword\"\r\n                    type='password'\r\n                    placeholder=\"Re Password *\"\r\n                    margin=\"normal\"\r\n                    required\r\n                    fullWidth\r\n                    variant=\"outlined\"\r\n                    className={classes.inputText}\r\n                    onChange={validatePassword}\r\n                    ></TextField>\r\n                    <FormControlLabel\r\n                    control={<Checkbox value=\"remember\" color=\"primary\" />}\r\n                    label=\"Accept with the rule of website\"\r\n                    />\r\n                    <Button\r\n                    type=\"submit\"\r\n                    className={classes.button} \r\n                    fullWidth                      \r\n                    >Sign Up</Button>\r\n                    <Grid container spacing={1}>\r\n                        <Grid item className={classes.linkGroup}>\r\n                            <Link className={classes.link}\r\n                            to=\"/signup\">\r\n                                {\"Already have an account? Sign in\"}\r\n                            </Link>\r\n                        </Grid>\r\n                    </Grid>\r\n                </form>\r\n            </Grid>\r\n        </Grid>\r\n    );\r\n}\r\nexport default SignUp;","E:\\React\\Chat App\\chat-app\\src\\components\\SignUp\\styles.js",[],"E:\\React\\Chat App\\chat-app\\src\\reportWebVitals.js",[],"E:\\React\\Chat App\\chat-app\\src\\store\\configStore.js",[],"E:\\React\\Chat App\\chat-app\\src\\config\\UI.cfg.js",[],"E:\\React\\Chat App\\chat-app\\src\\store\\reducers\\authReducer.js",[],"E:\\React\\Chat App\\chat-app\\src\\store\\actions\\authActions.js",[],"E:\\React\\Chat App\\chat-app\\src\\components\\SignUp\\services.js",[],"E:\\React\\Chat App\\chat-app\\src\\App.js",["83"],"import {BrowserRouter, Redirect, Route, Switch } from 'react-router-dom';\nimport {useSelector} from 'react-redux';\nimport RealTimeSocket from './realtime';\nimport Auth from './containers/Auth';\nimport {ThemeProvider} from \"@material-ui/core\";\nimport theme from \"./config/UI.cfg\";\nimport { ToastContainer } from 'react-toastify';\n\n\nfunction App() {  \n    //RealTimeSocket.getInstance();\n    const jwtToken = useSelector(state => state.auth.jwtToken);\n    \n    return (\n        <ThemeProvider theme={theme}>\n        <BrowserRouter>\n            <ToastContainer\n        